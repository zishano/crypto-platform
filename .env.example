# =====================================================================
# Crypto Platform - Phase 1 (READ-ONLY)
# =====================================================================
# 铁律 / IRON RULE:
#   - 本文件仅允许公共配置（交易所名称、交易对、同步频率等）。
#   - 严禁添加 API_SECRET / PRIVATE_KEY / API_KEY 等任何身份凭证。
#   - Phase 1 仅使用交易所 Public API，不接触账户/资金。
# =====================================================================

# 交易所名称（CCXT 支持的 id，例如：gate, binance, okx, kucoin）
EXCHANGE_NAME=gate

# SYMBOLS 支持两种模式：
#   1) auto[:N]    自动发现 Top N USDT 对（按 24h 成交量，N 默认 100，范围 1..500）
#                  自动过滤稳定币和杠杆代币（USDC/USDT, BTC3L/BTC3S 等）
#                  会自然包含当日热门 / 高波动币（meme、AI、新币）
#   2) 手动列表    形如 BTC/USDT,ETH/USDT,DOGE/USDT
SYMBOLS=auto:100

# 行情同步频率（秒）
SYNC_INTERVAL_SECONDS=30

# K 线周期：1m, 5m, 15m, 1h, 4h, 1d
KLINE_TIMEFRAME=1d

# 每次拉取的 K 线条数上限
KLINE_LIMIT=200

# 本地 SQLite 数据库路径
DB_PATH=./market_data.db

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
